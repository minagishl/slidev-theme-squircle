{
  "name": "slidev-theme-squircle",
  "version": "0.0.0",
  "type": "module",
  "description": "A Slidev theme with squircle frames and switchable color palettes",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minagishl/slidev-theme-squircle.git"
  },
  "files": [
    "components",
    "layouts",
    "styles",
    "setup",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "slidev build example.md",
    "build:cloudflare": "bun run build && rm ./dist/_redirects",
    "deploy": "bun run build:cloudflare && wrangler deploy",
    "dev": "slidev example.md --open",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@slidev/types": "^52.16.0",
    "gen-interface-jp": "^0.6.2",
    "lucide-static": "^0.576.0"
  },
  "devDependencies": {
    "@slidev/cli": "^52.16.0",
    "playwright-chromium": "^1.60.0",
    "prettier": "^3.8.4",
    "prettier-plugin-slidev": "^1.0.5",
    "wrangler": "^3.114.17"
  },
  "//": "Learn more: https://sli.dev/guide/write-theme.html",
  "slidev": {
    "colorSchema": "both",
    "defaults": {
      "themeConfig": {
        "font": "gen-interface-jp",
        "ellipsisFont": "cjk",
        "color": "teal"
      },
      "fonts": {
        "sans": "Gen Interface JP",
        "mono": "Fira Code"
      }
    }
  }
}
